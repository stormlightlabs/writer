<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Writer{% endblock %}</title>
  <meta name="description" content="{% block description %}A local-first markdown writing environment{% endblock %}">
  <link rel="icon" type="image/png" href="/static/images/favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600;700&family=Lora:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <header class="header">
    <div class="container header-inner">
      <a href="/index.html" class="logo">
        <img class="logo-icon" src="/static/images/icon.png" alt="" width="34" height="34">
        Writer
      </a>
      <nav class="nav">
        <a href="/index.html" class="nav-link {% if currentPath == 'index.html' %}active{% endif %}" {% if currentPath == "index.html" %}aria-current="page"{% endif %}>Home</a>
        <a href="/docs.html" class="nav-link {% if currentPath == 'docs.html' %}active{% endif %}" {% if currentPath == "docs.html" %}aria-current="page"{% endif %}>Docs</a>
        <a href="https://github.com/stormlightlabs/writer" class="nav-link" target="_blank" rel="noreferrer">Code</a>
        <a href="https://github.com/stormlightlabs/writer/releases" class="nav-link" target="_blank" rel="noreferrer">Download</a>
      </nav>
    </div>
  </header>

  <main>
    {% block content %}{{ content | safe }}{% endblock %}
  </main>

  <footer class="footer">
    <div class="container">
      <p class="footer-text">Built with ⚡️ in Austin, TX. Open source, local-first.</p>
      <p class="footer-links">
        <a href="https://github.com/stormlightlabs/writer" target="_blank" rel="noreferrer">Repository</a>
        <a href="https://github.com/stormlightlabs/writer/releases" target="_blank" rel="noreferrer">Releases</a>
      </p>
    </div>
  </footer>
</body>
</html>
